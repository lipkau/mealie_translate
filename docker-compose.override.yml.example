# docker-compose.override.yml.example
# Copy this file to docker-compose.override.yml and customize as needed
# This file allows you to override settings without modifying the main docker-compose.yml

services:
  mealie-translator:
    environment:
      # Override cron schedule
      # Examples:
      # Daily at 2 AM:     CRON_SCHEDULE: "0 2 * * *"
      # Every 4 hours:     CRON_SCHEDULE: "0 */4 * * *"
      # Twice daily:       CRON_SCHEDULE: "0 6,18 * * *"
      # Every 30 minutes:  CRON_SCHEDULE: "*/30 * * * *"
      CRON_SCHEDULE: "0 */6 * * *"

      # Override other settings
      # BATCH_SIZE: 20
      # TARGET_LANGUAGE: "Spanish"
      # LOG_LEVEL: "DEBUG"
